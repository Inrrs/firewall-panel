# 应用密钥（用于 session 加密，请修改为随机字符串）
SECRET_KEY=change-me-to-random-string

# 管理员凭据
ADMIN_USER=admin
ADMIN_PASS=change-me-to-strong-password

# 监听端口
LISTEN_PORT=8901

# 会话超时（秒）
SESSION_TIMEOUT=1800

# 登录失败锁定次数
MAX_LOGIN_ATTEMPTS=5

# 公网 HTTPS 部署时启用（设置为 1 或 true）
# 启用后会设置 Secure cookie 和 HSTS 头
HTTPS_ENABLED=
